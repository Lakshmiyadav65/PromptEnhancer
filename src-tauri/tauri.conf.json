{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptForge",
  "version": "0.1.0",
  "identifier": "com.promptforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PromptForge",
        "width": 400,
        "height": 300,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "status",
        "url": "index.html#/status",
        "title": "PromptForge Status",
        "width": 220,
        "height": 70,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../prompts/enhancer-system-prompt.md": "prompts/enhancer-system-prompt.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
